<VirtualHost *:443>
  ServerName my-abls-console.mydomain

  SSLEngine on
  SSLCertificateFile /etc/letsencrypt/live/my-abls-console.mydomain/cert.pem
  SSLCertificateKeyFile /etc/letsencrypt/live/my-abls-console.mydomain/privkey.pem
  SSLCertificateChainFile /etc/letsencrypt/live/my-abls-console.mydomain/chain.pem
  SSLProtocol all -SSLv2 -SSLv3 -TLSv1 -TLSv1.1
  SSLCompression      off
  SSLSessionTickets   off
  SSLHonorCipherOrder on
  SSLCipherSuite      ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-SHA384:ECDHE-RSA-AES256-SHA384:ECDHE-ECDSA-AES128-SHA256:ECDHE-RSA-AES128-SHA256

  CustomLog "logs/console_access.log" "%v %h %l %u %t \"%r\" %>s %b"

  ProxyPreserveHost On
  SSLProxyEngine On
  SecRuleEngine off

#Protection par authentification OIDC
  OIDCProviderMetadataURL https://my-idp.abls-habitat.fr/realms/my-realm/.well-known/openid-configuration
  OIDCClientID my-client-id
  OIDCClientSecret my-client-secret
  OIDCRedirectURI https://my-abls-console.mydomain/redirect_uri
  OIDCCryptoPassphrase change
  OIDCProviderIssuer https://my-idp.abls-habitat.fr/realms/my-realm
  OIDCResponseType code
  OIDCScope "openid profile email"
  OIDCStripCookies On
  OIDCPassAccessToken off

# ROUTING (ordre important : le plus spécifique d'abord)
ProxyPass        /api/ http://my-api:5562/ nocanon upgrade=websocket
ProxyPassReverse /api/ http://my-api:5562/

#Active l'authentification et passe les tokens
  <Location /api/>
    AuthType openid-connect
    Require valid-user
    OIDCPassIDTokenAs serialized
  </Location>

#Au choix: soit en proxy, soit en local
#  <Location />
#    AuthType openid-connect
#    Require valid-user
#  </Location>

  DocumentRoot /var/www/html/abls-console/public
  <Directory "/var/www/html/abls-console/public">
    AllowOverride All
    AuthType openid-connect
    Require valid-user
  </Directory>

</VirtualHost>
